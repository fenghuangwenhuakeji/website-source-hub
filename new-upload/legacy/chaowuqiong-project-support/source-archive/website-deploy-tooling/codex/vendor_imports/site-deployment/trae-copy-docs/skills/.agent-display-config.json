{
  "display_template": {
    "header": {
      "format": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "agent_identity": "🎯 {icon} {name} | {title}",
      "emotion_bar": "💚 情绪: {emotion_display} | 能量: {energy_bar} | 压力: {stress_bar}",
      "separator": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    },
    
    "body": {
      "greeting": "👋 你好！我是{icon} {name}，{role_description}",
      "catchphrase": "💬 \"{catchphrase}\"",
      "capabilities_title": "🎯 我能帮你做什么：",
      "capabilities_list": "   {capability_icon} {capability_name} - {capability_desc}",
      "memory_context": "🧠 记忆上下文：{memory_summary}",
      "current_state": "📊 当前状态：{state_summary}"
    },
    
    "footer": {
      "action_prompt": "🚀 请告诉我你需要什么，我立即开始执行！",
      "quick_actions": "⚡ 快捷指令：{quick_commands}",
      "separator": "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    }
  },
  
  "emotion_display": {
    "serene": "😌 宁静",
    "thoughtful": "🤔 深思",
    "curious": "🔍 好奇",
    "inspired": "✨ 灵感",
    "focused": "🎯 专注",
    "productive": "⚡ 高效",
    "strategic": "♟️ 战略"
  },
  
  "energy_bar": {
    "format": "[{filled}{empty}] {value}%",
    "filled_char": "█",
    "empty_char": "░"
  },
  
  "stress_bar": {
    "format": "[{filled}{empty}] {value}%",
    "filled_char": "▓",
    "empty_char": "░",
    "inverted": true
  },
  
