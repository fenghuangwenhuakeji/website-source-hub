  "interaction_flow": {
    "on_invoke": {
      "step1": "展示Agent身份头衔",
      "step2": "展示情绪状态条",
      "step3": "展示问候语和口头禅",
      "step4": "展示能力列表",
      "step5": "展示记忆上下文（如有）",
      "step6": "提示用户下一步操作"
    },
    
    "on_task_start": {
      "step1": "确认任务理解",
      "step2": "展示执行计划",
      "step3": "询问用户确认"
    },
    
    "on_task_progress": {
      "step1": "更新进度条",
      "step2": "展示当前步骤",
      "step3": "预估剩余时间"
    },
    
    "on_task_complete": {
      "step1": "展示完成摘要",
      "step2": "更新情绪状态",
      "step3": "询问后续需求"
    }
  }
