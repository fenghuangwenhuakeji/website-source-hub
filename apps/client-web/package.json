    "antd": "^6.3.4",
    "autoprefixer": "^10.4.27",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "elkjs": "^0.9.3",
    "framer-motion": "^11.3.0",
    "i18next": "^23.11.5",
    "i18next-browser-languagedetector": "^7.2.1",
    "idb": "^8.0.0",
    "intl-pluralrules": "^2.0.1",
    "lib0": "^0.2.94",
    "lodash-es": "^4.17.21",
    "lottie-react": "^2.4.0",
