{
  "name": "chaowuqiong-desktop",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "description": "超无穹主 Web 客户端",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "debug": "vite --debug",
    "build:test": "NODE_ENV=test vite build",
    "build": "vite build",
    "build:analyze": "NODE_ENV=production ANALYZE=analyze vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "npm run build && npm --prefix ../client-desktop run prepare:dist && npm --prefix ../client-desktop run start",
    "electron:start": "npm --prefix ../client-desktop run prepare:dist && npm --prefix ../client-desktop run start",
    "electron:build": "npm run build && npm --prefix ../client-desktop run build:win",
    "electron:build:win": "npm run build && npm --prefix ../client-desktop run build:win",
    "copy-static": "node -e \"const fs=require('fs');const path=require('path');const srcDir=path.join(__dirname,'static-content');const distDir=path.join(__dirname,'dist','static');[['long','long'],['short','short'],['novel','novel']].forEach(([name,folder])=>{const src=path.join(srcDir,folder);const dest=path.join(distDir,name);if(fs.existsSync(src)){fs.mkdirSync(dest,{recursive:true});fs.cpSync(src,dest,{recursive:true});console.log('Copied',src,'to',dest);}});console.log('Static files copied successfully!');\""
  },
