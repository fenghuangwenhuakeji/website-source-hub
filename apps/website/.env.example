# Desktop installer distribution
# Leave empty to keep the current origin paths under /downloads/fenghuang/.
# The default origin filenames are versioned, for example:
# /downloads/fenghuang/fenghuang-windows-setup-1.0.2.exe
# Recommended: upload installers to OSS/CDN and point this at that directory.
VITE_DESKTOP_DOWNLOAD_BASE_URL=

# Optional per-file overrides. These win over VITE_DESKTOP_DOWNLOAD_BASE_URL.
VITE_DESKTOP_DOWNLOAD_WINDOWS_URL=
VITE_DESKTOP_DOWNLOAD_WINDOWS_PORTABLE_URL=
VITE_DESKTOP_DOWNLOAD_MAC_DMG_URL=
VITE_DESKTOP_DOWNLOAD_MAC_ZIP_URL=
