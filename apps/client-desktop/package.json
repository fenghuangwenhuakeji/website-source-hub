{
  "name": "@website-source-hub/client-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Thin Electron shell for the normalized client-web bundle",
  "main": "electron/main.js",
  "author": "Fenghuang Team",
  "license": "MIT",
  "scripts": {
    "prepare:dist": "node ./scripts/prepare-dist.mjs",
    "start": "electron .",
    "build:win": "npm run prepare:dist && electron-builder --config electron-builder.json --win",
    "build:win:acceptance": "node ./scripts/build-win-acceptance.mjs"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
