# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change_me
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_EXPIRES_IN=365d

# Database
DB_ADAPTER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=chaowuqiong_db
DB_SQLITE_PATH=./data/local-dev.sqlite

# Local storage roots
DATA_ROOT=./data
STORAGE_ROOT=./data/storage
CACHE_ROOT=./data/cache
SESSION_DIR=./data/storage/sessions
USER_FILES_ROOT=./data/storage/user-files
USER_IMPORTS_ROOT=./data/storage/user-files/imports
USER_UPLOADS_ROOT=./data/storage/user-files/uploads
NOVEL_MIRROR_ROOT=./data/storage/novel-mirror
DATA_MIGRATION_ROOT=./data/migrations

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# WeChat Pay
# Use the payment-authorized service-account/public-account AppID here.
WECHAT_PAY_APPID=your_wechat_pay_appid
# Legacy fallback, kept for compatibility.
WECHAT_APPID=your_wechat_pay_appid
WECHAT_APPSECRET=your_wechat_appsecret
WECHAT_MCH_ID=your_merchant_id
WECHAT_API_KEY=your_wechat_api_v2_key
WECHAT_PAY_API_V3_KEY=your_wechat_api_v3_key
WECHAT_PAY_SERIAL_NO=your_merchant_api_certificate_serial
WECHAT_PAY_PRIVATE_KEY=your_apiclient_key_pem_content
WECHAT_PAY_PUBLIC_KEY=your_wechat_pay_public_key_content
WECHAT_PAY_PUBLIC_KEY_ID=your_wechat_pay_public_key_id
WECHAT_CALLBACK_URL=https://your-domain.com/api/payment/wechat/callback

# WeChat Website Login
WECHAT_LOGIN_APPID=your_wechat_login_appid
WECHAT_LOGIN_APPSECRET=your_wechat_login_appsecret
WECHAT_LOGIN_CALLBACK_DOMAIN=your-domain.com

# Alipay
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key
ALIPAY_CALLBACK_URL=https://your-domain.com/api/payment/alipay/callback

# Volcengine SMS
VOLCENGINE_ACCESS_KEY_ID=your_volcengine_access_key_id
VOLCENGINE_SECRET_KEY=your_volcengine_secret_key
VOLCENGINE_SMS_ACCOUNT=your_sms_account
VOLCENGINE_SMS_SIGN=your_sms_sign
VOLCENGINE_SMS_TEMPLATE_ID=your_sms_template_id

# CORS
CORS_ORIGIN=http://localhost:5173,https://your-domain.com
