{
  "name": "chaowuqiong-codeeditor",
  "version": "1.0.0",
  "description": "超无穹代码编辑器",
  "main": "electron/main.js",
  "scripts": {
    "electron:dev": "electron .",
    "electron:build": "electron-builder --config electron-builder.json --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.chaowuqiong.codeeditor",
    "productName": "超无穹代码编辑器",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "app/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/icon.ico",
      "uninstallerIcon": "electron/assets/icon.ico",
      "installerHeaderIcon": "electron/assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0"
  }
}
